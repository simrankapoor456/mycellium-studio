# Browser-safe Supabase configuration. Data authorization must come from RLS.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional server-only provider configuration. Never use a NEXT_PUBLIC prefix.
OPENAI_API_KEY=optional-server-provider-key
OPENAI_MODEL=optional-provider-model
